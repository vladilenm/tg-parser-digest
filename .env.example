# =============================================================================
# tg-parser-demo — пример окружения. Скопируй в .env и заполни реальные значения.
# ВНИМАНИЕ: .env находится в .gitignore. Никогда не публикуй секреты.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram user-session (чтение каналов через GramJS / MTProto)
# -----------------------------------------------------------------------------
# https://my.telegram.org → API development tools → App api_id
TG_API_ID=
# https://my.telegram.org → API development tools → App api_hash
TG_API_HASH=
# StringSession: генерируется через `npm run login`, скопировать сюда
TG_SESSION=

# -----------------------------------------------------------------------------
# Telegram bot (доставка дайджеста в приватный канал)
# -----------------------------------------------------------------------------
# @BotFather → /newbot → скопировать токен
TG_BOT_TOKEN=
# -100xxxxxxxxxx (приватный канал, бот — admin). Получить через @username_to_id_bot
TG_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Telegram bot commands (управление каналами через бота, BOT-04)
# -----------------------------------------------------------------------------
# Comma-separated numeric Telegram user.id, имеющих доступ к командам бота.
# Узнать свой numeric id: написать @userinfobot, скопировать "Id".
# Пример: BOT_ALLOWED_USER_IDS=12345678,87654321
# Если переменная пуста или не задана — bot polling не запускается, daemon стартует только с cron.
BOT_ALLOWED_USER_IDS=

# -----------------------------------------------------------------------------
# DeepSeek (LLM-суммаризация через OpenAI-совместимый SDK)
# -----------------------------------------------------------------------------
# https://platform.deepseek.com → API keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Размер чанка для Pass 1 классификации в src/summarize.ts.
# При больших прогонах (200+ постов) один LLM-запрос упирается в client timeout 120s.
# Разбиваем посты на чанки и классифицируем параллельно через Promise.allSettled.
# Дефолт 40 проверен на проде; уменьшать при FloodWait/таймаутах, увеличивать только осознанно.
CLASSIFY_CHUNK_SIZE=40

# -----------------------------------------------------------------------------
# Параметры прогона
# -----------------------------------------------------------------------------
FETCH_WINDOW_HOURS=24
MAX_MESSAGES_PER_CHANNEL=50
# базовая задержка между каналами; к ней добавляется jitter 0–2500мс (итого 1.5–4 сек)
CHANNEL_DELAY_MS=1500
# debug | info | warn | error
LOG_LEVEL=info
# Cron-расписание для daemon-режима (src/run.ts). 5-полевой формат, TZ=Europe/Moscow.
# К указанному времени добавляется рандомный jitter 0–30 минут.
# Дефолт: ежедневно в 21:00 MSK. Примеры: "0 21 * * *" (21:00), "15 20 * * *" (20:15), "0 9,21 * * *" (09:00 и 21:00).
CRON_SCHEDULE=0 21 * * *

# -----------------------------------------------------------------------------
# Alert-bot (ALERT-01): отдельный Bot API для технических ошибок pipeline.
# Шлёт в личку владельца, НЕ загрязняет канал Заказчика.
# -----------------------------------------------------------------------------
# @BotFather → /newbot → Bot Token (отдельный от delivery-бота выше)
BOT_TOKEN_ALERTS=
# Numeric chat_id личного чата владельца с alert-ботом.
# Узнать: начать диалог с alert-ботом (/start), переслать сообщение в @userinfobot.
ALERTS_CHAT_ID=
