# Dependencies
node_modules/

# Secrets
.env
.env.local

# Logs
*.log
# (data/run-*.log already covered by `data/*` below — listed here for grep-ability.)

# Runtime data archives (config + state + raw + output + logs + backups).
# Все мутабельные файлы живут под data/ (per docs/db-deploy.md §1).
# channels.json/websites.json в корне репо — seed-defaults, продолжают версионироваться.
data/*
!data/.gitkeep
# Generated dashboard artifact (dev-tool, не версионируется).
# Уже покрыто `data/*`, но прописано явно для grep-ability.
/data/dashboard/
# Local pre-deploy snapshots на VDS (создаются deploy.sh, не должны попасть в репо).
/opt/backups/

# OS
.DS_Store

# Editor
.vscode/
.idea/

