{
  "name": "tg-parser-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "login": "node --env-file=.env --import tsx scripts/login.ts",
    "start": "node --env-file=.env --import tsx src/run.ts",
    "start:once": "node --env-file=.env --import tsx scripts/run-once.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.0.0",
    "telegram": "^2.22.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
